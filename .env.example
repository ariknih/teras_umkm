# Environment variables for Teras UMKM Full-Stack App
# Copy this file to .env and configure with your credentials

# Prisma Database connection URL (PostgreSQL, MySQL, SQLite, etc.)
DATABASE_URL="postgresql://username:password@localhost:5432/teras_umkm?schema=public"
DIRECT_URL="postgresql://username:password@localhost:5432/teras_umkm?schema=public"

# JWT Secret Key for token validation
JWT_SECRET="your-super-secret-jwt-key-change-this"

# Local/Production URL of the application
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Google Services (Maps, OAuth)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-google-maps-api-key"
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Komerce API (Sandbox Mode)
KOMERCE_SHIPPING_API_KEY="your-komerce-shipping-api-key"
KOMERCE_PAYMENT_API_KEY="your-komerce-payment-api-key"
KOMERCE_QRISLY_API_KEY="your-komerce-qrisly-api-key"
KOMERCE_BASE_URL="https://api-sandbox.collaborator.komerce.id"

# Midtrans Configuration (Sandbox)
MIDTRANS_SERVER_KEY="your-midtrans-server-key"
MIDTRANS_CLIENT_KEY="your-midtrans-client-key"
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY="your-midtrans-client-key"
MIDTRANS_MERCHANT_ID="your-midtrans-merchant-id"
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_IS_SANITIZED=true
MIDTRANS_IS_3DS=true
