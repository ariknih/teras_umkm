// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

enum Role {
  CUSTOMER
  MERCHANT
  AFFILIATE
  ADMIN
  CUSTOMER_SERVICE
}

enum ProductCategory {
  TOKO
  KAFE
  JASA
  KERJAAN
  ELEKTRONIK
  MAKANAN_MINUMAN
  KOMPUTER_AKSESORIS
  PERAWATAN_KECANTIKAN
  HANDPHONE_AKSESORIS
  PERLENGKAPAN_RUMAH
  PAKAIAN_PRIA
  PAKAIAN_WANITA
  SEPATU_PRIA
  FASHION_MUSLIM
  TAS_PRIA
  FASHION_BAYI_ANAK
  AKSESORIS_FASHION
  IBU_BAYI
  JAM_TANGAN
  SEPATU_WANITA
  KESEHATAN
  TAS_WANITA
  HOBI_KOLEKSI
  OTOMOTIF
  OLAHRAGA_OUTDOOR
  BUKU_ALAT_TULIS
  SOUVENIR_PERLENGKAPAN_PESTA
  FOTOGRAFI
  VOUCHER
  DEALS_SEKITAR
}

enum OrderStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  SALE
  COMMISSION
}

enum CoinTxType {
  TOPUP
  REWARD_USER_INVITE
  REWARD_MERCHANT_INVITE
  REDEEM_VOUCHER
  DISTRIBUTE          // Ketua distribusi ke member
  INJECTION           // Inject manual oleh Superadmin
  REFERRAL_COMMISSION // Komisi 3 koin cross-community ke referrer
}

enum VoucherType {
  INTERNAL // Voucher diskon platform sendiri
  EXTERNAL // Voucher pihak ketiga (TikTok, Shopee, dll)
}

enum RedemptionStatus {
  PENDING
  CLAIMED
  EXPIRED
}

enum PayoutStatus {
  PENDING
  PAID
  FAILED
}

enum CommunityType {
  PERKUMPULAN
  KOPERASI
}

// Kategori komunitas yang lebih granular
enum CommunityCategory {
  FREE     // Komunitas Gratis — min topup 100 koin
  PAID     // Komunitas Berbayar — min topup 1.000 koin
  KOPERASI // Koperasi — simpanan pokok + wajib
}

enum KycStatus {
  NOT_SUBMITTED
  PENDING
  APPROVED
  REJECTED
  VERIFIED
}

enum LoanStatus {
  PENDING
  APPROVED_KETUA
  APPROVED_ADMIN
  DISBURSED
  REJECTED
}

enum LevelRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  username     String?       @unique // Kode referral (unik, tidak bisa sama)
  name         String
  image        String?       // Profile picture URL
  passwordHash String
  role         Role          @default(CUSTOMER)
  isSuperAdmin Boolean       @default(false)  // Superadmin flag — hanya 1 akun
  latitude     Float?
  longitude    Float?
  level        Int           @default(1)
  xp           Int           @default(0)
  points       Float         @default(0.0)
  coinBalance  Float         @default(0.0) // Saldo coin pribadi
  bootcampStatus String      @default("NONE") // "NONE", "QUALIFIED", "JOINED"
  landingPageTemplate String?
  landingPageConfig   String?
  landingPageSetup    Boolean       @default(false)
  parentAffiliateId String?
  parentAffiliate   User?        @relation("AffiliateTree", fields: [parentAffiliateId], references: [id])
  subAffiliates     User[]       @relation("AffiliateTree")
  membershipLevel   String       @default("Reseller") // "Reseller", "Agen", "Distributor"
  membershipAccess  String       @default("Gold")     // "Gold", "Platinum", "Diamond"
  // Level Area Merchant (L0 = belum punya level, L1-L4)
  merchantLevel     Int          @default(0)
  levelApprovedAt   DateTime?
  levelApprovedBy   String?      // ID Superadmin yang approve
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  // KYC fields
  kycStatus         KycStatus    @default(NOT_SUBMITTED)
  kycKtpUrl         String?
  kycSelfieUrl      String?
  kycSubmittedAt    DateTime?
  kycSessionId      String?
  kycVerifiedAt     DateTime?

  // Komunitas Induk (set saat pertama kali daftar, tidak bisa diganti)
  indukCommunityId  String?
  
  // Integrations Settings
  waGatewayKeys    String        @default("")
  fbPixelId        String?
  tiktokPixelId    String?
  zapierWebhookUrl String?
  googleSheetUrl   String?
  zoomMeetingUrl   String?
  emailTemplate    String?

  // Relations
  products     Product[]     @relation("MerchantProducts")
  orders       Order[]       @relation("BuyerOrders")
  progress     Progress[]
  posts        Post[]
  comments     Comment[]
  postLikes    PostLike[]
  ownedGroups  CommunityGroup[] @relation("GroupAdmin")
  groupMembers GroupMember[]

  // Community relations (new hierarchy)
  ownedCommunities    Community[]          @relation("CommunityKetua")
  communityMemberships CommunityMembership[]

  buyerRooms   ChatRoom[]      @relation("BuyerRooms")
  sellerRooms  ChatRoom[]      @relation("SellerRooms")
  supportTickets SupportTicket[] @relation("CustomerTickets")
  assignedTickets SupportTicket[] @relation("CsAgentTickets")
  
  // Affiliate relations
  referrals    AffiliateReferral[] @relation("AffiliateReferrals")
  purchases    AffiliateReferral[] @relation("ReferredBuyerPurchases")
  
  wallet       Wallet?
  notifications Notification[]
  reviews       ProductReview[]
  
  // Coin relations
  coinTransactions  CoinTransaction[]   @relation("UserCoinTx")
  coinRedemptions   CoinRedemption[]
  referralsMade     UserReferral[]      @relation("ReferrerUser")  // orang yang diundang oleh user ini
  referredBy        UserReferral[]      @relation("ReferredUser")  // siapa yang mengundang user ini
  merchantInvitesSent    MerchantInvite[] @relation("InviterMerchant")
  merchantInvitesReceived MerchantInvite[] @relation("InviteeMerchant")
  levelRequests          MerchantLevelRequest[] @relation("MerchantLevelRequests")
}

model Product {
  id          String          @id @default(uuid())
  title       String
  description String
  price       Float
  category    ProductCategory @default(TOKO)
  stock       Int             @default(0)
  imageUrl    String?
  latitude    Float?
  longitude   Float?
  jvPartnerId String?
  jvSharePercent Float?
  isAffiliateEnabled      Boolean @default(false)
  affiliateCommissionType String  @default("PERCENT") // "PERCENT" or "FIXED"
  affiliateCommissionValue Float  @default(0.0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  
  // Relations
  merchantId  String
  merchant    User            @relation("MerchantProducts", fields: [merchantId], references: [id], onDelete: Cascade)
  orderItems  OrderItem[]
  chatRooms   ChatRoom[]
  reviews     ProductReview[]
}

model Order {
  id              String      @id @default(uuid())
  totalAmount     Float
  status          OrderStatus @default(PENDING)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  shippingFee     Float?
  courier         String?
  shippingAddress String?
  shippingLabel   String?
  couponCode      String?
  discountAmount  Float?
  bumpSales       String?
  
  // Relations
  buyerId     String
  buyer       User        @relation("BuyerOrders", fields: [buyerId], references: [id], onDelete: Cascade)
  items       OrderItem[]
  tracking    OrderTracking[]
}

model OrderItem {
  id        String   @id @default(uuid())
  quantity  Int
  price     Float
  
  // Relations
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Course {
  id          String   @id @default(uuid())
  title       String
  description String
  coverImage  String?
  accessRequired String   @default("Gold") // "Gold", "Platinum", "Diamond"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  lessons     Lesson[]
}

model Lesson {
  id         String     @id @default(uuid())
  title      String
  content    String
  videoUrl   String?
  duration   Int        @default(0) // In seconds
  orderIndex Int
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  
  // Relations
  courseId   String
  course     Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress   Progress[]
}

model Progress {
  id        String   @id @default(uuid())
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId  String
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  
  @@unique([userId, lessonId])
}

model Post {
  id        String    @id @default(uuid())
  title     String
  content   String
  imageUrl  String?
  videoUrl  String?
  category  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  
  // Relations
  authorId  String
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments  Comment[]
  likes     PostLike[]
  groupId   String?
  group     CommunityGroup? @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model PostLike {
  id        String   @id @default(uuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
}

model CommunityGroup {
  id          String        @id @default(uuid())
  name        String
  description String
  coverUrl    String?
  avatarUrl   String?
  isSuspended Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Creator / Admin of this group
  adminId     String
  admin       User          @relation("GroupAdmin", fields: [adminId], references: [id], onDelete: Cascade)
  
  // Relations
  posts       Post[]
  members     GroupMember[]
}

model GroupMember {
  id        String         @id @default(uuid())
  groupId   String
  group     CommunityGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())

  @@unique([groupId, userId])
}



model Comment {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model AffiliateReferral {
  id          String       @id @default(uuid())
  amount      Float
  status      PayoutStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  
  // Relations
  affiliateId String
  affiliate   User         @relation("AffiliateReferrals", fields: [affiliateId], references: [id], onDelete: Cascade)
  buyerId     String
  buyer       User         @relation("ReferredBuyerPurchases", fields: [buyerId], references: [id], onDelete: Cascade)
}

model Wallet {
  id           String              @id @default(uuid())
  balance      Float               @default(0.0)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  
  // Relations
  userId       String              @unique
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]
}

model WalletTransaction {
  id          String          @id @default(uuid())
  amount      Float
  type        TransactionType
  description String
  createdAt   DateTime        @default(now())
  
  // Relations
  walletId    String
  wallet      Wallet          @relation(fields: [walletId], references: [id], onDelete: Cascade)
}

model ChatRoom {
  id          String        @id @default(uuid())
  buyerId     String
  buyer       User          @relation("BuyerRooms", fields: [buyerId], references: [id], onDelete: Cascade)
  sellerId    String
  seller      User          @relation("SellerRooms", fields: [sellerId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product?      @relation(fields: [productId], references: [id], onDelete: SetNull)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  messages    ChatMessage[]

  @@unique([buyerId, sellerId])
}

model ChatMessage {
  id         String   @id @default(uuid())
  roomId     String
  room       ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  senderId   String
  content    String
  imageUrl   String?
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model SupportTicket {
  id           String           @id @default(uuid())
  ticketNumber String           @unique
  customerId   String
  customer     User             @relation("CustomerTickets", fields: [customerId], references: [id], onDelete: Cascade)
  csAgentId    String?
  csAgent      User?            @relation("CsAgentTickets", fields: [csAgentId], references: [id], onDelete: SetNull)
  status       String           @default("OPEN") // "OPEN", "PENDING", "RESOLVED", "ESCALATED"
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  messages     SupportMessage[]
}

model SupportMessage {
  id             String        @id @default(uuid())
  ticketId       String
  ticket         SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderId       String
  content        String
  imageUrl       String?
  isRead         Boolean       @default(false)
  isInternalNote Boolean       @default(false)
  createdAt      DateTime      @default(now())
}

// 1. Product Reviews
model ProductReview {
  id        String   @id @default(uuid())
  rating    Int      // 1–5
  comment   String
  createdAt DateTime @default(now())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  orderId   String?  // hanya bisa review setelah order
  @@unique([productId, authorId])
}

// 2. In-App Notifications
model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // ORDER_PLACED, REVIEW_RECEIVED, CHAT_MESSAGE, TICKET_UPDATE
  title     String
  body      String
  isRead    Boolean  @default(false)
  linkUrl   String?
  createdAt DateTime @default(now())
}

// 3. Order Tracking Steps
model OrderTracking {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    String   // CONFIRMED, PROCESSING, SHIPPED, DELIVERED, CANCELLED
  note      String?
  createdAt DateTime @default(now())
}

// ═══════════════════════════════════════════════════════════════════════════════
// Komunitas Induk (Revisi Pert Keempat)
// ═══════════════════════════════════════════════════════════════════════════════

model Community {
  id                String            @id @default(uuid())
  name              String
  type              CommunityType     @default(PERKUMPULAN)
  category          CommunityCategory @default(FREE) // FREE | PAID | KOPERASI
  aktaNotaris       String?
  nomorAhu          String?
  nomorNpwp         String?
  domisili          String?
  kontakPj          String?
  description       String?
  coverUrl          String?
  avatarUrl         String?
  landingPageConfig String?
  waGroupLink       String?

  // Iuran (hanya untuk PAID/KOPERASI)
  joinFee           Float             @default(0)
  monthlyFee        Float             @default(0)

  // Koperasi: simpanan
  simpananPokok     Float             @default(100000) // Rp 100.000
  simpananWajib     Float             @default(25000)  // Rp 25.000/bulan

  // Coin komunitas
  coinBalance       Float             @default(0.0)    // Kas coin komunitas
  minCoinForLoan    Float             @default(1000.0) // Min coin untuk buka akses pinjaman
  minCoinRequired   Float             @default(100.0)  // Min topup awal (100 FREE, 1000 PAID)
  isRecruitmentLocked Boolean         @default(false)  // Auto-lock bila saldo coin = 0

  isSuspended       Boolean           @default(false)
  isVerified        Boolean           @default(false)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  // Ketua Komunitas
  ketuaId           String
  ketua             User              @relation("CommunityKetua", fields: [ketuaId], references: [id])

  // Members
  members           CommunityMembership[]

  // Keuangan Koperasi
  loanRequests      CooperativeLoan[]

  // Coin komunitas
  coinTransactions  CoinTransaction[] @relation("CommunityCoinTx")
}

model CommunityMembership {
  id              String      @id @default(uuid())
  communityId     String
  community       Community   @relation(fields: [communityId], references: [id], onDelete: Cascade)
  userId          String
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  isInduk         Boolean     @default(false)
  isPaid          Boolean     @default(false)
  // Untuk KOPERASI: simpanan
  simpananPokok   Float?      // Rp 100.000 sekali bayar
  simpananWajib   Float?      // Rp 25.000/bulan
  invoiceStatus   String      @default("UNPAID") // UNPAID | PAID | VERIFIED
  invoiceVerifiedAt DateTime?
  invoiceVerifiedBy String?   // ID Admin yang verifikasi
  joinedAt        DateTime    @default(now())

  @@unique([communityId, userId])
}

model CooperativeLoan {
  id              String      @id @default(uuid())
  communityId     String
  community       Community   @relation(fields: [communityId], references: [id], onDelete: Cascade)
  merchantId      String
  amount          Float
  purpose         String
  status          LoanStatus  @default(PENDING)
  approvedByKetua Boolean     @default(false)
  approvedByAdmin Boolean     @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

// ═══════════════════════════════════════════════════════════════════════════════
// Sistem Coin (Revisi Pert Kelima)
// ═══════════════════════════════════════════════════════════════════════════════

// Log semua transaksi coin (topup, reward undangan, redeem voucher)
model CoinTransaction {
  id          String      @id @default(uuid())
  type        CoinTxType
  amount      Float       // jumlah coin (positif = masuk, negatif = keluar)
  description String
  createdAt   DateTime    @default(now())

  // User yang terlibat (penerima coin)
  userId      String
  user        User        @relation("UserCoinTx", fields: [userId], references: [id], onDelete: Cascade)

  // Opsional: dikaitkan dengan komunitas (untuk topup komunitas)
  communityId String?
  community   Community?  @relation("CommunityCoinTx", fields: [communityId], references: [id], onDelete: SetNull)

  // Referensi objek terkait (opsional)
  relatedUserId    String? // user yang diundang / merchant yang diundang
  relatedVoucherId String? // voucher yang diredeem
}

// Master daftar voucher yang bisa ditukar coin
model CoinVoucher {
  id            String        @id @default(uuid())
  name          String
  description   String
  type          VoucherType   @default(INTERNAL)
  coinCost      Float         // berapa coin yang dibutuhkan
  value         Float         // nilai voucher dalam rupiah
  code          String?       // untuk EXTERNAL: kode voucher yang sudah ada
  maxRedemption Int           @default(0) // 0 = unlimited
  totalRedeemed Int           @default(0)
  isActive      Boolean       @default(true)
  validUntil    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  redemptions   CoinRedemption[]
}

// Log penukaran coin ke voucher oleh user
model CoinRedemption {
  id          String            @id @default(uuid())
  coinSpent   Float
  status      RedemptionStatus  @default(PENDING)
  claimCode   String?           // kode unik yang digenerate untuk user (INTERNAL)
  claimedAt   DateTime?
  createdAt   DateTime          @default(now())

  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  voucherId   String
  voucher     CoinVoucher       @relation(fields: [voucherId], references: [id], onDelete: Cascade)
}

// Log undangan user (siapa mengundang siapa — semua role)
// Reward: +1 coin untuk pengundang
model UserReferral {
  id              String    @id @default(uuid())
  coinAwarded     Float     @default(1.0)
  isRewarded      Boolean   @default(false)
  createdAt       DateTime  @default(now())

  referrerId      String
  referrer        User      @relation("ReferrerUser", fields: [referrerId], references: [id], onDelete: Cascade)

  referredId      String
  referred        User      @relation("ReferredUser", fields: [referredId], references: [id], onDelete: Cascade)

  @@unique([referrerId, referredId])
}

// Log undangan merchant ke komunitas yang sama
// Reward: COIN (PERKUMPULAN) atau SALDO WALLET (KOPERASI)
model MerchantInvite {
  id              String    @id @default(uuid())
  communityId     String
  communityType   String    // 'PERKUMPULAN' | 'KOPERASI'
  rewardType      String    // 'COIN' | 'SALDO'
  rewardAmount    Float     @default(1.0)
  isRewarded      Boolean   @default(false)
  createdAt       DateTime  @default(now())

  inviterId       String
  inviter         User      @relation("InviterMerchant", fields: [inviterId], references: [id], onDelete: Cascade)

  inviteeId       String
  invitee         User      @relation("InviteeMerchant", fields: [inviteeId], references: [id], onDelete: Cascade)
}

// ═══════════════════════════════════════════════════════════════════════════════
// Konfigurasi Sistem Koin (Dikelola oleh Superadmin)
// Singleton — hanya 1 row dengan id = "singleton"
// ═══════════════════════════════════════════════════════════════════════════════

model CoinSystemConfig {
  id                  String   @id @default("singleton")
  coinRateRupiah      Float    @default(1500.0) // Nilai 1 koin dalam Rupiah (dinamis)
  minTopupFree        Int      @default(100)    // Min topup awal komunitas FREE
  minTopupPaid        Int      @default(1000)   // Min topup awal komunitas PAID/KOPERASI
  referralCoinAmount  Int      @default(3)      // Jumlah koin reward referral cross-community
  updatedAt           DateTime @updatedAt
  updatedBy           String?                  // ID Superadmin yang terakhir update
}

// ═══════════════════════════════════════════════════════════════════════════════
// Sistem Level Up Merchant (L1–L4, disetujui Superadmin)
// ═══════════════════════════════════════════════════════════════════════════════

model MerchantLevelRequest {
  id              String              @id @default(uuid())
  userId          String
  user            User                @relation("MerchantLevelRequests", fields: [userId], references: [id], onDelete: Cascade)
  targetLevel     Int                 // 1, 2, 3, atau 4
  status          LevelRequestStatus  @default(PENDING)

  // Kriteria yang perlu dipenuhi
  radiusKm        Float?              // Jangkauan area KM (L1=5, L2=10, L3=35, L4=beyond)
  omsetBulan      Float?              // Omset bulanan (requirement: >= 10.000.000)
  hasLegalitas    Boolean             @default(false)
  hasSertifikat   Boolean             @default(false)
  hasDesain       Boolean             @default(false)
  catatan         String?             // Catatan dari merchant

  // Review oleh Superadmin
  reviewNote      String?
  reviewedAt      DateTime?
  reviewedBy      String?             // ID Superadmin yang review

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
}
